# App
APP_ENV=local
LOG_LEVEL=INFO
PORT=8000
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./app.db

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
SLACK_COWORKER_USER_ID=U01234567
PLAN_NOTIFY_COWORKER_ON_CREATE=true
PLAN_BACKEND=manual
PLAN_EXECUTE_ON_APPROVE=true

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=

# Salesforce
SALESFORCE_DOMAIN=login
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_SECRET=
SALESFORCE_OAUTH_REDIRECT_URI=
OAUTH_STATE_SECRET=
TOKEN_ENCRYPTION_KEY=

# Read backend selection: salesforce_api | salesforce_mcp
READ_BACKEND=salesforce_api

# Salesforce DX MCP (optional)
# Example:
# SALESFORCE_MCP_COMMAND=npx
# SALESFORCE_MCP_ARGS=-y @salesforce/mcp@latest --orgs DEFAULT_TARGET_ORG --toolsets orgs,data --tools list_all_orgs,get_username,run_soql_query
SALESFORCE_MCP_COMMAND=
SALESFORCE_MCP_ARGS=
SALESFORCE_MCP_ENV_JSON={}
SALESFORCE_MCP_INIT_TIMEOUT_SECONDS=20
SALESFORCE_MCP_TOOL_TIMEOUT_SECONDS=90

# Knowledge ingestion (read-response to structured KB facts/hypotheses/questions)
KNOWLEDGE_INGESTION_ENABLED=true
KNOWLEDGE_INGESTION_MAX_ITEMS=30
